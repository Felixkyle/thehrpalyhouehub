# Root .env for docker-compose. Copy to `.env` on the VPS and fill in.
#   cp .env.example .env  &&  nano .env
# Compose substitutes these into docker-compose.yml.

# ── App ────────────────────────────────────────────────────────
FRONTEND_URL=https://thehrplayhousehub.org

JWT_SECRET=CHANGE_ME_min_32_random_chars_use_openssl_rand_hex_32
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

RESEND_API_KEY=
EMAIL_FROM=The HR Playhouse Hub <contact@thehrplayhousehub.org>

# ── MongoDB (container) ────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=hrplay
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_strong_db_password

# Backend connects to the mongo *service* with the same credentials.
# Keep USER/PASS in sync with the two vars above.
MONGODB_URI=mongodb://hrplay:CHANGE_ME_strong_db_password@mongo:27017/hrplayhouse?authSource=admin
