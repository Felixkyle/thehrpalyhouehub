# ── Server ─────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────────────
# Local dev (no Docker):
MONGODB_URI=mongodb://127.0.0.1:27017/hrplayhouse
#
# In Docker, the whole stack reads THIS file (backend/.env). Use the mongo
# SERVICE NAME + auth, and set the root creds the mongo container initialises:
# MONGO_INITDB_ROOT_USERNAME=hrplay
# MONGO_INITDB_ROOT_PASSWORD=<a-long-random-password>
# MONGODB_URI=mongodb://hrplay:<same-password>@mongo:27017/hrplayhouse?authSource=admin
#
# FRONTEND_URL in Docker should be your real site:
# FRONTEND_URL=https://thehrplayhousehub.org

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ── AI HR Support (Google Gemini) ──────────────────────────────
# Get a key: https://aistudio.google.com/apikey  (blank = AI chat returns 502)
# Use gemini-2.5-flash — it has a free tier (gemini-2.5-pro often does not).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# (legacy — no longer used; kept for reference)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Email (Resend) ─────────────────────────────────────────────
# https://resend.com — verify the sending domain first.
# If RESEND_API_KEY is empty, emails are logged to console instead of sent.
RESEND_API_KEY=
EMAIL_FROM=The HR Playhouse Hub <contact@thehrplayhousehub.org>

# Where enquiry/form notifications are sent. Defaults to contact@... .
CONTACT_INBOX=contact@thehrplayhousehub.org

# ── Temporary, BEFORE the Resend domain is verified ───────────
# Resend only lets an unverified account send FROM onboarding@resend.dev and
# only TO your own Resend account email. To test delivery now, set:
#   EMAIL_FROM=The HR Playhouse Hub <onboarding@resend.dev>
#   CONTACT_INBOX=<your-resend-account-email>
# Once the domain is verified, switch both back to your real @thehrplayhousehub.org values.
